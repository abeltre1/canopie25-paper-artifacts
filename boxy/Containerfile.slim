# Containerized boxy — SLIM flavor, TWO-STAGE:
#   build stage    docker.io/library/python:<PYVER>        (full image = builder)
#   runtime stage  docker.io/library/python:<PYVER>-slim   (runtime)
# The general-purpose counterpart to the Red Hat hardened flavor in
# ./Containerfile: official python image, Debian, apt-installed OpenSSH client.
#
# Build:
#   python -m build --wheel .          # -> dist/boxy_hpc-*.whl
#   podman build -t boxy:slim -f Containerfile.slim .
#
# Run — SSH material and state ride in as mounts (nothing baked in):
#   podman run --rm -it \
#     -v ~/.ssh:/home/boxy/.ssh:ro \
#     -v ~/.config/boxy:/home/boxy/.config/boxy \
#     -v boxy-state:/home/boxy/.local \
#     boxy:slim serve hf://Qwen/Qwen2.5-0.5B-Instruct --ssh mycluster
#
# Agent forwarding: -v $SSH_AUTH_SOCK:/ssh-agent -e SSH_AUTH_SOCK=/ssh-agent

ARG PYVER=3.14
FROM docker.io/library/python:${PYVER} AS build

# the wheel is built by CI (or `make wheel`) right before the image build;
# install into an isolated prefix so the runtime COPY is exact
COPY dist/*.whl /tmp/dist/
RUN pip install --no-cache-dir --prefix=/install /tmp/dist/*.whl && rm -rf /tmp/dist

ARG PYVER
FROM docker.io/library/python:${PYVER}-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends openssh-client ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# the official python images live under /usr/local — the prefix copy lands
# boxy on the runtime python's own path (bin/ console script + site-packages)
COPY --from=build /install/ /usr/local/

RUN useradd --create-home boxy
USER boxy
WORKDIR /home/boxy

ENTRYPOINT ["boxy"]
CMD ["--help"]
